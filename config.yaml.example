taxonomy:
  - id: "autoresearch_loops"
    name: "Autoresearch Loops"
    query_keywords:
      - "autoresearch"
      - "auto research"
      - "self-improving training loop"
      - "research loop"
      - "automated research loop"
      - "autonomous research loop"
      - "karpathy autoresearch"
    exclude_keywords: []
    repo_tags: ["reference-loop", "overnight-research"]
    readme_section: "Key Papers By Theme"
  - id: "end_to_end_ai_scientists"
    name: "End-to-End AI Scientists"
    query_keywords:
      - "AI scientist"
      - "AI-Scientist"
      - "automated AI researcher"
      - "autonomous scientific innovation"
      - "agentic tree search"
      - "scientist bench"
      - "research agent"
    exclude_keywords: []
    repo_tags: ["ai-scientist", "end-to-end"]
    readme_section: "Key Papers By Theme"
  - id: "closed_loop_empirical_science"
    name: "Closed-Loop Empirical Science"
    query_keywords:
      - "closed-loop empirical research"
      - "automated research assistant"
      - "AutoRA"
      - "experimentalist"
      - "theorist"
      - "equation discovery"
    exclude_keywords: []
    repo_tags: ["closed-loop-science"]
    readme_section: "Key Papers By Theme"
  - id: "autonomous_discovery"
    name: "Autonomous Discovery"
    query_keywords:
      - "autodiscovery"
      - "autonomous discovery"
      - "scientific discovery agent"
      - "hypothesis search"
      - "bayesian surprise"
      - "open-ended discovery"
    exclude_keywords: []
    repo_tags: ["discovery"]
    readme_section: "Key Papers By Theme"
  - id: "literature_and_survey_agents"
    name: "Literature And Survey Agents"
    query_keywords:
      - "literature review agent"
      - "survey generation"
      - "deep research"
      - "research survey agent"
      - "paper synthesis"
    exclude_keywords: []
    repo_tags: ["retrieval", "survey"]
    readme_section: "Key Papers By Theme"
  - id: "research_infrastructure_and_benchmarks"
    name: "Research Infrastructure And Benchmarks"
    query_keywords:
      - "scientist bench"
      - "science automation framework"
      - "research benchmark"
      - "continual science automation"
      - "multiagent research framework"
      - "research infrastructure"
    exclude_keywords: []
    repo_tags: ["benchmarks", "infra"]
    readme_section: "Key Papers By Theme"

sources:
  arxiv:
    enabled: true
    max_per_query: 20
    days_lookback: 3
  nature:
    enabled: false
  huggingface:
    enabled: true
    max_papers: 100

scoring:
  top_k: 25
  dimensions:
    fit_to_auto_research: 0.35
    methodological_significance: 0.30
    ecosystem_relevance: 0.20
    likely_longevity: 0.15

archive:
  archive_max: 8
  min_score: 7.5
  featured_min_score: 8.8
  card_format: "markdown"

readme:
  recent_limit: 10
  featured_limit: 5

curation:
  featured_source: "archived"

llm:
  model: "gpt-5"
  temperature: 0.2
  max_tokens: 4096

email:
  enabled: false
  smtp_server: "smtp.gmail.com"
  smtp_port: 587
  sender: ""
  recipient: ""

output:
  reports_dir: "reports"
  archive_dir: "archive"
  data_dir: "data"
